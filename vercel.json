{
  "version": 2,
  "name": "medical-ai-frontend",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "@api-url"
  },
  "build": {
    "env": {
      "REACT_APP_API_URL": "@api-url"
    }
  },
  "functions": {
    "frontend/src/**": {
      "includeFiles": "frontend/dist/**"
    }
  }
}